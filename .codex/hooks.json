{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd); PRESENCE_GUARD_HOST=codex bash \"$ROOT/.agents/hooks/presence-guard.sh\"'",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"E:/projects/virtual-office/.codex/hooks/gsd-context-monitor.cmd\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"E:/projects/virtual-office/.codex/hooks/gsd-check-update.cmd\"",
            "commandWindows": "\"E:/projects/virtual-office/.codex/hooks/gsd-check-update.cmd\""
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"E:/projects/virtual-office/.codex/hooks/gsd-context-monitor.cmd\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"E:/projects/virtual-office/.codex/hooks/gsd-context-monitor.cmd\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"E:/projects/virtual-office/.codex/hooks/gsd-context-monitor.cmd\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"E:/projects/virtual-office/.codex/hooks/gsd-context-monitor.cmd\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"E:/projects/virtual-office/.codex/hooks/gsd-context-monitor.cmd\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"E:/projects/virtual-office/.codex/hooks/gsd-context-monitor.cmd\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"E:/projects/virtual-office/.codex/hooks/gsd-context-monitor.cmd\"",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"E:/projects/virtual-office/.codex/hooks/gsd-context-monitor.cmd\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
