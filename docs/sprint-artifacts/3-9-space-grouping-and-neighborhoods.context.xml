  <databaseSchema>
    <table name="neighborhoods">
      <column name="id" type="UUID" primaryKey="true" default="gen_random_uuid()" />
      <column name="company_id" type="UUID" foreignKey="companies(id)" onDelete="CASCADE" />
      <column name="name" type="TEXT" notNull="true" />
      <column name="description" type="TEXT" nullable="true" />
      <column name="color" type="TEXT" notNull="true" default="'--vo-neighborhood-1'" />
      <column name="created_at" type="TIMESTAMPTZ" notNull="true" default="now()" />
      <column name="updated_at" type="TIMESTAMPTZ" notNull="true" default="now()" />
      <constraint type="unique" columns="company_id, name" />
    </table>
    <migration name="add_neighborhood_id_to_spaces">
      <sql><![CDATA[
ALTER TABLE spaces
ADD COLUMN neighborhood_id UUID REFERENCES neighborhoods(id) ON DELETE SET NULL;
      ]]></sql>
    </migration>
    <rls table="neighborhoods">
      <policy name="Company members can read neighborhoods" operation="SELECT">
        <using>auth.uid() IN (SELECT user_id FROM company_users WHERE company_id = neighborhoods.company_id)</using>
      </policy>
      <policy name="Company admins can manage neighborhoods" operation="ALL">
        <using>auth.uid() IN (SELECT user_id FROM company_users WHERE company_id = neighborhoods.company_id AND role = 'admin')</using>
      </policy>
    </rls>
  </databaseSchema>

